# =============================================================================
# Auth API (registro e inicio de sesión)
# =============================================================================
# URL base del servicio de autenticación (sin barra final).
# Debe ser una URL absoluta (http:// o https://). Ejemplo: http://localhost:8080
# Si está vacía o es relativa, las peticiones irían al servidor Next.js y darían 404.
# Las peticiones se harán a: {NEXT_PUBLIC_AUTH_API_URL}/api/auth/login,
# {NEXT_PUBLIC_AUTH_API_URL}/api/organizations/:id/branding, etc.
NEXT_PUBLIC_AUTH_API_URL=http://localhost:8080

# =============================================================================
# Otros servicios (opcionales)
# =============================================================================
# NOTIFICATIONS_SERVICE_URL=http://localhost:3002
# CONFIGURATION_SERVICE_URL=http://localhost:3002

# Credenciales demo (opcional, solo si quieres pre-rellenar el login en desarrollo)
# NEXT_PUBLIC_DEMO_USER_MAIL=
# NEXT_PUBLIC_DEMO_USER_PASS=
